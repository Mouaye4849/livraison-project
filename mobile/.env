# ─── WASALI Mobile — API URL ──────────────────────────────────────────────────
#
# Leave EXPO_PUBLIC_API_URL empty in development.
# The app auto-detects the correct URL every Expo start via Metro hostUri
# (same LAN IP as the machine running Vite), so this never goes stale after
# a network change, PC restart, or Wi-Fi reconnect.
#
# Only set this for production or if auto-detection fails:
# EXPO_PUBLIC_API_URL=http://192.168.x.x:5173/api
