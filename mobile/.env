# ─── WASALI Mobile — network URLs ─────────────────────────────────────────────
#
# REST API — via Vite proxy (auto-detected via Metro hostUri, no need to set)
# EXPO_PUBLIC_API_URL=http://192.168.43.37:5173/api

# SockJS/STOMP — DIRECT to Spring Boot (no Vite proxy needed for SockJS)
# SockJS uses HTTP for the /info handshake then upgrades to WebSocket.
# Laissé VIDE : auto-détection via Metro hostUri (s'adapte à chaque changement
# de réseau sans édition manuelle). Ne décommenter que pour forcer une IP fixe.
# EXPO_PUBLIC_CHAT_URL=http://192.168.43.37:8080/chat
